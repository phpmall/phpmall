#!/usr/bin/env bash

# Pre-commit hook: run backend lint checks on staged PHP files
# To install: composer git-hooks

set -e

echo "[pre-commit] Running Laravel Pint check..."

# Get staged PHP files
STAGED_PHP_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.php$' || true)

if [ -z "$STAGED_PHP_FILES" ]; then
    echo "[pre-commit] No PHP files staged, skipping."
    exit 0
fi

# Run Pint only on staged files
vendor/bin/pint --config=pint.json --test $(echo "$STAGED_PHP_FILES" | tr '\n' ' ')

echo "[pre-commit] Laravel Pint check passed."
