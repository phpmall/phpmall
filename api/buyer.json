    "components": {
        "schemas": {
            "ForgetMobileRequest": {
                "required": [
                    "mobile",
                    "captcha",
                    "uuid"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "1234"
                    },
                    "uuid": {
                        "description": "图片验证码UUID",
                        "type": "string",
                        "example": "abc"
                    }
                },
                "type": "object"
            },
            "LoginRequest": {
                "required": [
                    "username",
                    "password",
                    "captcha",
                    "uuid"
                ],
                "properties": {
                    "username": {
                        "description": "登录用户名",
                        "type": "string",
                        "example": "name"
                    },
                    "password": {
                        "description": "登录密码",
                        "type": "string",
                        "example": "md5密码"
                    },
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "1234"
                    },
                    "uuid": {
                        "description": "图片验证码UUID",
                        "type": "string",
                        "example": "abc"
                    },
                    "remember": {
                        "description": "记住我",
                        "type": "string",
                        "example": "off"
                    }
                },
                "type": "object"
            },
            "LoginSmsRequest": {
                "required": [
                    "mobile",
                    "code"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "code": {
                        "description": "短信验证码",
                        "type": "string",
                        "example": "123456"
                    }
                },
                "type": "object"
            },
            "ResetRequest": {
                "required": [
                    "mobile",
                    "password",
                    "captcha",
                    "uuid"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "password": {
                        "description": "登录密码",
                        "type": "string",
                        "example": "123456aA"
                    },
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "1234"
                    },
                    "uuid": {
                        "description": "图片验证码UUID",
                        "type": "string",
                        "example": "abc"
                    }
                },
                "type": "object"
            },
            "SignupMobileRequest": {
                "required": [
                    "mobile",
                    "code",
                    "accept_term"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "code": {
                        "description": "短信验证码",
                        "type": "string",
                        "example": "123456"
                    },
                    "accept_term": {
                        "description": "是否接受注册协议",
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "LoginResponse": {
                "properties": {
                    "token": {
                        "description": "用户JSON Web Token凭证",
                        "type": "string",
                        "example": "123456"
                    }
                },
                "type": "object"
            },
            "CaptchaResponse": {
                "properties": {
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "123456"
                    },
                    "uuid": {
                        "description": "验证码UUID",
                        "type": "string",
                        "example": "123456"
                    }
                },
                "type": "object"
            },
            "RegionRequest": {
                "properties": {
                    "id": {
                        "description": "地区ID",
                        "type": "integer"
                    }
                },
                "type": "object"
            },
            "RegionResponse": {
                "properties": {
                    "id": {
                        "description": "地区ID",
                        "type": "integer"
                    },
                    "name": {
                        "description": "地区名称",
                        "type": "string"
                    },
                    "first_letter": {
                        "description": "地区名称首字母",
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "SmsSendRequest": {
                "required": [
                    "mobile",
                    "captcha",
                    "uuid"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "000000"
                    },
                    "uuid": {
                        "description": "图片验证码UUID",
                        "type": "string",
                        "example": "123456"
                    }
                },
                "type": "object"
            },
            "AddressCreateRequest": {
                "required": [
                    "mobile"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    }
                },
                "type": "object"
            },
            "AddressQueryRequest": {
                "required": [
                    "mobile"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    }
                },
                "type": "object"
            },
            "AddressUpdateRequest": {
                "required": [
                    "mobile"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    }
                },
                "type": "object"
            },
            "ProfileRequest": {
                "required": [
                    "name"
                ],
                "properties": {
                    "name": {
                        "description": "名称",
                        "type": "string",
                        "example": "名称"
                    }
                },
                "type": "object"
            },
            "AddressResponse": {
                "properties": {
                    "id": {
                        "description": "编号",
                        "type": "integer",
                        "example": 1
                    }
                },
                "type": "object"
            },
            "ProfileResponse": {
                "properties": {
                    "id": {
                        "description": "编号",
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "description": "名称",
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "OptionResponse": {
                "properties": {
                    "name": {
                        "description": "名称",
                        "type": "string",
                        "example": "name"
                    },
                    "val": {
                        "description": "值",
                        "type": "integer",
                        "example": 1
                    }
                },
                "type": "object"
            },
            "PaginateLinkVo": {
                "properties": {
                    "url": {
                        "description": "链接URL",
                        "type": "string"
                    },
                    "label": {
                        "description": "页标签",
                        "type": "string"
                    },
                    "next": {
                        "description": "当前页",
                        "type": "boolean"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "description": "JWT 认证信息",
                "name": "Authorization",
                "in": "header",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    }
}