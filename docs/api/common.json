{
    "openapi": "3.0.0",
    "info": {
        "title": "API文档",
        "description": "基础平台接口",
        "contact": {
            "name": "API Develop Team"
        },
        "version": "1.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000/api/common",
            "description": "开发环境"
        }
    ],
    "paths": {
        "/upload": {
            "post": {
                "tags": [
                    "素材"
                ],
                "summary": "附件上传接口",
                "operationId": "7344a54bc539006807309c39793bc8ad",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/UploadRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UploadResponse"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/captcha": {
            "get": {
                "tags": [
                    "验证码"
                ],
                "summary": "图片验证码",
                "operationId": "a65b88b9fda72070b59fc09fc63de277",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CaptchaResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/region": {
            "get": {
                "tags": [
                    "地区"
                ],
                "summary": "查询地区列表",
                "operationId": "7dfe7c2e610f5cc15bf293081c90610e",
                "parameters": [
                    {
                        "name": "id",
                        "in": "query",
                        "description": "上级地区ID，默认值为0显示省份数据",
                        "required": true,
                        "example": 0
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RegionResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/sms": {
            "post": {
                "tags": [
                    "短信"
                ],
                "summary": "发送手机短信验证码",
                "operationId": "dae7391b59f293bc000c565fe4bd4c02",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/SmsSendRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "UploadRequest": {
                "required": [
                    "file"
                ],
                "properties": {
                    "file": {
                        "description": "文件",
                        "type": "file",
                        "format": "binary"
                    }
                },
                "type": "object"
            },
            "UploadResponse": {
                "properties": {
                    "url": {
                        "description": "素材URL地址",
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "CaptchaResponse": {
                "properties": {
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "123456"
                    },
                    "uuid": {
                        "description": "验证码UUID",
                        "type": "string",
                        "example": "123456"
                    }
                },
                "type": "object"
            },
            "RegionRequest": {
                "properties": {
                    "id": {
                        "description": "地区ID",
                        "type": "integer"
                    }
                },
                "type": "object"
            },
            "RegionResponse": {
                "properties": {
                    "id": {
                        "description": "地区ID",
                        "type": "integer"
                    },
                    "name": {
                        "description": "地区名称",
                        "type": "string"
                    },
                    "first_letter": {
                        "description": "地区名称首字母",
                        "type": "string"
                    }
                },
                "type": "object"
            },
            "SmsSendRequest": {
                "required": [
                    "mobile",
                    "captcha",
                    "uuid"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "000000"
                    },
                    "uuid": {
                        "description": "图片验证码UUID",
                        "type": "string",
                        "example": "123456"
                    }
                },
                "type": "object"
            }
        }
    }
}