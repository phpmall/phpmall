{
    "openapi": "3.0.0",
    "info": {
        "title": "API文档",
        "description": "提供买家API接口",
        "contact": {
            "name": "API Develop Team"
        },
        "version": "1.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000",
            "description": "开发环境"
        },
        {
            "url": "https://api.demo.phpmall.net",
            "description": "测试环境"
        }
    ],
    "paths": {
        "/user/address": {
            "get": {
                "tags": [
                    "收货地址"
                ],
                "summary": "获取用户全部收货地址",
                "operationId": "57e44b3898a0ec63108ca4951cc1b10a",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "description": "当前页码",
                        "required": true,
                        "example": 1
                    },
                    {
                        "name": "pageSize",
                        "in": "query",
                        "description": "每页分页数",
                        "required": false,
                        "example": 10
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AddressQueryRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AddressResponse"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/user/address/store": {
            "post": {
                "tags": [
                    "收货地址"
                ],
                "summary": "新增用户收货地址",
                "operationId": "37ba6e8d6371e4f61e39ec8b9aebd834",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AddressCreateRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/user/address/show": {
            "get": {
                "tags": [
                    "收货地址"
                ],
                "summary": "查询用户收货地址",
                "operationId": "0c742cf0ad166177c95a91cac4a1c563",
                "parameters": [
                    {
                        "name": "id",
                        "in": "query",
                        "description": "收货地址ID",
                        "required": true,
                        "example": 1
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AddressResponse"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/user/address/update": {
            "put": {
                "tags": [
                    "收货地址"
                ],
                "summary": "更新用户收货地址",
                "operationId": "1b3144304236f02861aee3f558daccb6",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AddressUpdateRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/user/address/destroy": {
            "delete": {
                "tags": [
                    "收货地址"
                ],
                "summary": "删除用户收货地址",
                "operationId": "3c42ad2294d91567ecd94a2efefdd1af",
                "parameters": [
                    {
                        "name": "id",
                        "in": "query",
                        "description": "收货地址ID",
                        "required": true,
                        "example": 1
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/user/profile": {
            "get": {
                "tags": [
                    "用户资料"
                ],
                "summary": "获取用户详细信息",
                "operationId": "fe29864c0f74ee011266afdfc9f322e9",
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "/user": {
            "get": {
                "tags": [
                    "用户中心"
                ],
                "summary": "仪表台",
                "operationId": "da06530dd892102eaf0131b9a5b0e5a2",
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "AddressCreateRequest": {
                "required": [
                    "mobile"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    }
                },
                "type": "object"
            },
            "AddressQueryRequest": {
                "required": [
                    "mobile"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    }
                },
                "type": "object"
            },
            "AddressUpdateRequest": {
                "required": [
                    "mobile"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    }
                },
                "type": "object"
            },
            "AddressResponse": {
                "properties": {
                    "id": {
                        "description": "编号",
                        "type": "integer",
                        "example": 1
                    }
                },
                "type": "object"
            },
            "ProfileResponse": {
                "properties": {
                    "id": {
                        "description": "编号",
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "description": "名称",
                        "type": "string"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "description": "JWT 认证信息",
                "name": "Authorization",
                "in": "header",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    }
}