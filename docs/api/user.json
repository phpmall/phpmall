{
    "openapi": "3.0.0",
    "info": {
        "title": "API文档",
        "description": "提供买家API接口",
        "contact": {
            "name": "API Develop Team"
        },
        "version": "1.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000/api/user/",
            "description": "开发环境"
        }
    ],
    "paths": {
        "address": {
            "get": {
                "tags": [
                    "收货地址"
                ],
                "summary": "获取用户全部收货地址",
                "operationId": "a96eae36c528566818e88f43d66cb55c",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "description": "当前页码",
                        "required": true,
                        "example": 1
                    },
                    {
                        "name": "pageSize",
                        "in": "query",
                        "description": "每页分页数",
                        "required": false,
                        "example": 10
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AddressQueryRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AddressResponse"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "address/store": {
            "post": {
                "tags": [
                    "收货地址"
