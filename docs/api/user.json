{
    "openapi": "3.0.0",
    "info": {
        "title": "API文档",
        "description": "提供买家API接口",
        "contact": {
            "name": "API Develop Team"
        },
        "version": "1.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000/api/user/",
            "description": "开发环境"
        },
        {
            "url": "https://demo.phpmall.net/api/user/",
            "description": "演示环境"
        }
    ],
    "paths": {
        "/dashboard": {
            "get": {
                "tags": [
                    "用户中心"
                ],
                "summary": "仪表台",
                "operationId": "e79cbcc3a42f869179d2330111533960",
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/address": {
            "get": {
                "tags": [
                    "收货地址"
                ],
                "summary": "获取用户全部收货地址",
                "operationId": "b004afc6b9fc29e0f370deea38917a2c",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "description": "当前页码",
                        "required": true,
                        "example": 1
                    },
                    {
                        "name": "pageSize",
                        "in": "query",
                        "description": "每页分页数",
                        "required": false,
                        "example": 10
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AddressQueryRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AddressResponse"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/address/store": {
            "post": {
                "tags": [
                    "收货地址"
                ],
                "summary": "新增用户收货地址",
                "operationId": "da6ef6c573a55a47f47fd4e30600b7ef",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AddressCreateRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/address/show": {
            "get": {
                "tags": [
                    "收货地址"
                ],
                "summary": "查询用户收货地址",
                "operationId": "5cdfecb0410b9816d74f1124f1a48ca6",
                "parameters": [
                    {
                        "name": "id",
                        "in": "query",
                        "description": "收货地址ID",
                        "required": true,
                        "example": 1
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AddressResponse"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/address/update": {
            "put": {
                "tags": [
                    "收货地址"
                ],
                "summary": "更新用户收货地址",
                "operationId": "89a594f45c6a2cebcc2433730868172d",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AddressUpdateRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/address/destroy": {
            "delete": {
                "tags": [
                    "收货地址"
                ],
                "summary": "删除用户收货地址",
                "operationId": "66fdf71811e1215f8076a5e17f080c39",
                "parameters": [
                    {
                        "name": "id",
                        "in": "query",
                        "description": "收货地址ID",
                        "required": true,
                        "example": 1
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/profile/show": {
            "get": {
                "tags": [
                    "用户中心"
                ],
                "summary": "获取用户资料",
                "operationId": "f72aec94dd85622c72fce62d3f6a39b9",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ProfileResponse"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/profile/update": {
            "put": {
                "tags": [
                    "用户中心"
                ],
                "summary": "更新用户资料",
                "operationId": "c49a9ec46c016018d68c85f522e0599e",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "App\\Bundles\\User\\Requests\\ProfileRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "AddressCreateRequest": {
                "required": [
                    "mobile"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    }
                },
                "type": "object"
            },
            "AddressQueryRequest": {
                "required": [
                    "mobile"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    }
                },
                "type": "object"
            },
            "AddressUpdateRequest": {
                "required": [
                    "mobile"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    }
                },
                "type": "object"
            },
            "AddressResponse": {
                "properties": {
                    "id": {
                        "description": "编号",
                        "type": "integer",
                        "example": 1
                    }
                },
                "type": "object"
            },
            "ProfileResponse": {
                "properties": {
                    "id": {
                        "description": "编号",
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "description": "名称",
                        "type": "string"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "description": "JWT 认证信息",
                "name": "Authorization",
                "in": "header",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    }
}