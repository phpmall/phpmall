{
    "openapi": "3.0.0",
    "info": {
        "title": "API文档",
        "description": "认证平台接口",
        "contact": {
            "name": "API Develop Team"
        },
        "version": "1.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000",
            "description": "开发环境"
        },
        {
            "url": "https://api.demo.phpmall.net",
            "description": "测试环境"
        }
    ],
    "paths": {
        "/auth/captcha": {
            "get": {
                "tags": [
                    "验证码"
                ],
                "summary": "图片验证码",
                "operationId": "ec641b6efcf6c3ea82e8f5e13608681d",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CaptchaResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/forget/mobile": {
            "post": {
                "tags": [
                    "忘记密码"
                ],
                "summary": "发送手机短信验证码",
                "operationId": "5bdf1820aec0fb310d9a85e9a361a8c7",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ForgetMobileRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "/login": {
            "post": {
                "tags": [
                    "认证管理"
                ],
                "summary": "登录操作",
                "operationId": "d22c8ce1ffb25db8cc43f04181c0c8e3",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LoginResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/login/mobile2": {
            "post": {
                "tags": [
                    "登录"
                ],
                "summary": "通过手机号和密码登录",
                "operationId": "ca86e63a32ba1f161f1e87101630ec03",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginMobileRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LoginResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/login/mobile": {
            "post": {
                "tags": [
                    "登录"
                ],
                "summary": "通过手机短信验证码登录",
                "operationId": "066a8994b3917e9e5e05b073eb331ed4",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginSmsRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LoginResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/oauth/redirect": {
            "post": {
                "tags": [
                    "授权登录"
                ],
                "summary": "获取授权跳转地址",
                "operationId": "09ffdca5fc7b6235b015b7ef59f225ce",
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "/oauth/callback": {
            "post": {
                "tags": [
                    "授权登录"
                ],
                "summary": "授权登录回调地址",
                "operationId": "0cde938cb9e4ab9952fdb3ce8bb636e9",
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "/oauth/bind": {
            "post": {
                "tags": [
                    "授权登录"
                ],
                "summary": "新用户绑定接口",
                "operationId": "726fb37fb670b5e95cbb81aa574ec03c",
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "/reset": {
            "post": {
                "tags": [
                    "重设密码"
                ],
                "summary": "通过验证码重新设置新密码",
                "operationId": "475bd94c6115c4794792b4fadc95c208",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ResetRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "/signup/mobile": {
            "post": {
                "tags": [
                    "注册"
                ],
                "summary": "通过手机号码注册",
                "operationId": "11ec3d5edd2413eab6096ccccff1a0ac",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/SignupMobileRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "ForgetMobileRequest": {
                "required": [
                    "mobile",
                    "captcha"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "1234"
                    }
                },
                "type": "object"
            },
            "LoginMobileRequest": {
                "required": [
                    "mobile",
                    "password",
                    "captcha",
                    "uuid"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "password": {
                        "description": "登录密码",
                        "type": "string",
                        "example": "123456aA"
                    },
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "1234"
                    },
                    "uuid": {
                        "description": "验证码UUID",
                        "type": "string",
                        "example": "1234"
                    }
                },
                "type": "object"
            },
            "LoginRequest": {
                "required": [
                    "username",
                    "password",
                    "captcha",
                    "uuid"
                ],
                "properties": {
                    "username": {
                        "description": "登录用户名",
                        "type": "string",
                        "example": "15858589988"
                    },
                    "password": {
                        "description": "登录密码",
                        "type": "string",
                        "example": "md5密码"
                    },
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "1234"
                    },
                    "uuid": {
                        "description": "图片验证码UUID",
                        "type": "string",
                        "example": "abc"
                    }
                },
                "type": "object"
            },
            "LoginSmsRequest": {
                "required": [
                    "mobile",
                    "code"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "code": {
                        "description": "短信验证码",
                        "type": "string",
                        "example": "123456"
                    }
                },
                "type": "object"
            },
            "ResetRequest": {
                "required": [
                    "mobile",
                    "password",
                    "captcha"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "password": {
                        "description": "登录密码",
                        "type": "string",
                        "example": "123456aA"
                    },
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "1234"
                    }
                },
                "type": "object"
            },
            "SignupMobileRequest": {
                "required": [
                    "mobile",
                    "code",
                    "agreed"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "code": {
                        "description": "短信验证码",
                        "type": "string",
                        "example": "123456"
                    },
                    "agreed": {
                        "description": "注册协议",
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "CaptchaResponse": {
                "properties": {
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "123456"
                    },
                    "uuid": {
                        "description": "验证码UUID",
                        "type": "string",
                        "example": "123456"
                    }
                },
                "type": "object"
            },
            "LoginResponse": {
                "properties": {
                    "token": {
                        "description": "用户JSON Web Token凭证",
                        "type": "string",
                        "example": "123456"
                    }
                },
                "type": "object"
            }
        }
    }
}