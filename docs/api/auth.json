{
    "openapi": "3.0.0",
    "info": {
        "title": "API文档",
        "description": "认证平台接口",
        "contact": {
            "name": "API Develop Team"
        },
        "version": "1.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000/api/auth/",
            "description": "开发环境"
        }
    ],
    "paths": {
        "forget/mobile": {
            "post": {
                "tags": [
                    "忘记密码"
                ],
                "summary": "发送手机短信验证码",
                "operationId": "6980bdc8465c859e5a4916e30526e334",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ForgetMobileRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "login": {
            "post": {
                "tags": [
                    "登录"
                ],
                "summary": "通过用户名和密码登录",
                "operationId": "e3946f776659149b3e15c691227bd45e",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LoginResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "login/smsCode": {
            "post": {
                "tags": [
                    "登录"
                ],
                "summary": "通过手机短信验证码登录",
                "operationId": "7c8ffafb5a64bbf0e4d4cc6cec9d700c",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginSmsRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LoginResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "reset": {
            "post": {
                "tags": [
                    "重设密码"
                ],
                "summary": "通过验证码重新设置新密码",
                "operationId": "69c107e98996af1fbe263c0823c18abe",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ResetRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "signup/mobile": {
            "post": {
                "tags": [
                    "注册"
                ],
                "summary": "通过手机号码注册",
                "operationId": "8d4e432069f1c35803ec820b60bbe4a8",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/SignupMobileRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "oauth/redirect": {
            "post": {
                "tags": [
                    "开放授权登录"
                ],
                "summary": "获取授权跳转地址",
                "operationId": "51cb1503804f4509949b655efc32587b",
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "oauth/callback": {
            "post": {
                "tags": [
                    "开放授权登录"
                ],
                "summary": "授权登录回调地址",
                "operationId": "63bbbccdffa4f19a280ad48564218e65",
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "oauth/bind": {
            "post": {
                "tags": [
                    "开放授权登录"
                ],
                "summary": "新用户绑定接口",
                "operationId": "331786884ecc6f7b1eba65b159de3733",
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "ForgetMobileRequest": {
                "required": [
                    "mobile",
                    "captcha",
                    "uuid"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "1234"
                    },
                    "uuid": {
                        "description": "图片验证码UUID",
                        "type": "string",
                        "example": "abc"
                    }
                },
                "type": "object"
            },
            "LoginRequest": {
                "required": [
                    "username",
                    "password",
                    "captcha",
                    "uuid"
                ],
                "properties": {
                    "username": {
                        "description": "登录用户名",
                        "type": "string",
                        "example": "name"
                    },
                    "password": {
                        "description": "登录密码",
                        "type": "string",
                        "example": "md5密码"
                    },
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "1234"
                    },
                    "uuid": {
                        "description": "图片验证码UUID",
                        "type": "string",
                        "example": "abc"
                    },
                    "remember": {
                        "description": "记住我",
                        "type": "string",
                        "example": "off"
                    }
                },
                "type": "object"
            },
            "LoginSmsRequest": {
                "required": [
                    "mobile",
                    "code"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "code": {
                        "description": "短信验证码",
                        "type": "string",
                        "example": "123456"
                    }
                },
                "type": "object"
            },
            "ResetRequest": {
                "required": [
                    "mobile",
                    "password",
                    "captcha",
                    "uuid"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "password": {
                        "description": "登录密码",
                        "type": "string",
                        "example": "123456aA"
                    },
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "1234"
                    },
                    "uuid": {
                        "description": "图片验证码UUID",
                        "type": "string",
                        "example": "abc"
                    }
                },
                "type": "object"
            },
            "SignupMobileRequest": {
                "required": [
                    "mobile",
                    "code",
                    "accept_term"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "code": {
                        "description": "短信验证码",
                        "type": "string",
                        "example": "123456"
                    },
                    "accept_term": {
                        "description": "是否接受注册协议",
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "LoginResponse": {
                "properties": {
                    "token": {
                        "description": "用户JSON Web Token凭证",
                        "type": "string",
                        "example": "123456"
                    }
                },
                "type": "object"
            }
        }
    }
}