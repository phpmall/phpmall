{
    "openapi": "3.0.0",
    "info": {
        "title": "API文档",
        "description": "认证平台接口",
        "contact": {
            "name": "API Develop Team"
        },
        "version": "1.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000",
            "description": "开发环境"
        }
    ],
    "paths": {
        "/api/auth/forget/mobile": {
            "post": {
                "tags": [
                    "忘记密码"
                ],
                "summary": "发送手机短信验证码",
                "operationId": "d7d435244135ae6df6ec9346b8180985",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ForgetMobileRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "/api/auth/login/mobile": {
            "post": {
                "tags": [
                    "认证管理"
                ],
                "summary": "通过手机号和密码登录",
                "operationId": "ead033760aecdd510dccf406c6329e20",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LoginResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/login/mobile2": {
            "post": {
                "tags": [
                    "登录"
                ],
                "summary": "通过手机号和密码登录",
                "operationId": "2892c07cfb7f1a83fc2b99a89786a4a2",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginMobileRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LoginResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/login/mobile": {
            "post": {
                "tags": [
                    "登录"
                ],
                "summary": "通过手机短信验证码登录",
                "operationId": "00767b1aab0c94371cadf81a3b84a9db",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginSmsRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LoginResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/auth/reset": {
            "post": {
                "tags": [
                    "重设密码"
                ],
                "summary": "通过验证码重新设置新密码",
                "operationId": "41a30d0eb7ca61f679a1b91210b7c3d6",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ResetRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
        "/api/auth/signup/mobile": {
            "post": {
                "tags": [
                    "注册"
                ],
                "summary": "通过手机号码注册",
                "operationId": "b3c03f6a0a7e2d0b4e8c7bbfd3590e0e",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/SignupMobileRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "ForgetMobileRequest": {
                "required": [
                    "mobile",
                    "captcha"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "1234"
                    }
                },
                "type": "object"
            },
            "LoginMobileRequest": {
                "required": [
                    "mobile",
                    "password",
                    "captcha",
                    "uuid"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "password": {
                        "description": "登录密码",
                        "type": "string",
                        "example": "123456aA"
                    },
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "1234"
                    },
                    "uuid": {
                        "description": "验证码UUID",
                        "type": "string",
                        "example": "1234"
                    }
                },
                "type": "object"
            },
            "LoginRequest": {
                "required": [
                    "mobile",
                    "password",
                    "captcha",
                    "uuid"
                ],
                "properties": {
                    "mobile": {
                        "description": "登录手机号码",
                        "type": "string",
                        "example": "15858589988"
                    },
                    "password": {
                        "description": "登录密码",
                        "type": "string",
                        "example": "md5密码"
                    },
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "1234"
                    },
                    "uuid": {
                        "description": "图片验证码UUID",
                        "type": "string",
                        "example": "abc"
                    }
                },
                "type": "object"
            },
            "LoginSmsRequest": {
                "required": [
                    "mobile",
                    "code"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "code": {
                        "description": "短信验证码",
                        "type": "string",
                        "example": "123456"
                    }
                },
                "type": "object"
            },
            "ResetRequest": {
                "required": [
                    "mobile",
                    "password",
                    "captcha"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "password": {
                        "description": "登录密码",
                        "type": "string",
                        "example": "123456aA"
                    },
                    "captcha": {
                        "description": "图片验证码",
                        "type": "string",
                        "example": "1234"
                    }
                },
                "type": "object"
            },
            "SignupMobileRequest": {
                "required": [
                    "mobile",
                    "code",
                    "agreed"
                ],
                "properties": {
                    "mobile": {
                        "description": "手机号码",
                        "type": "string",
                        "example": "13901889999"
                    },
                    "code": {
                        "description": "短信验证码",
                        "type": "string",
                        "example": "123456"
                    },
                    "agreed": {
                        "description": "注册协议",
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "LoginResponse": {
                "properties": {
                    "token": {
                        "description": "用户JSON Web Token凭证",
                        "type": "string",
                        "example": "123456"
                    }
                },
                "type": "object"
            }
        }
    }
}