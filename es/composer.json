{
    "name": "ecboot/ecboot",
    "type": "project",
    "description": "High performance e-commerce system for PHP based on Octane.",
    "keywords": ["ecboot", "store", "laravel", "mysql", "redis", "swoole", "high performance"],
    "homepage": "https://www.ecboot.net/",
    "license": "Apache-2.0",
    "support": {
        "issues": "https://github.com/ecboot/ecboot/issues?state=open",
        "forum": "https://bbs.ecboot.net/",
        "wiki": "https://docs.ecboot.net/",
        "source": "https://github.com/ecboot/ecboot"
    },
    "require": {
        "php": "^8.2",
        "juling/laravel-foundation": "^1.0",
        "laravel/framework": "^11.0",
        "laravel/tinker": "^2.9"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "juling/laravel-devtools": "^1.0",
        "laravel/pint": "^1.14",
        "laravel/sail": "^1.29",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^10.5",
        "spatie/laravel-ignition": "^2.4",
        "zircote/swagger-php": "^4.8.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
