{
  "name": "phpmall",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp check && vp run -r test && vp run -r build",
    "dev": "vp run website#dev",
    "dev:admin": "vp run admin#dev",
    "dev:seller": "vp run seller#dev",
    "dev:supplier": "vp run supplier#dev",
    "dev:website": "vp run website#dev",
    "dev:mobile": "vp run mobile#dev",
    "dev:all": "pnpm --parallel --filter './apps/*' dev"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
