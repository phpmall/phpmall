{
    "name": "phpmall/phpmall",
    "type": "project",
    "description": "High performance e-commerce platform for PHP based on Octane.",
    "keywords": ["phpmall", "multi-store", "laravel", "mysql", "redis", "swoole", "high performance"],
    "homepage": "https://www.phpmall.net/",
    "license": "Apache-2.0",
    "support": {
        "issues": "https://github.com/phpmall/phpmall/issues?state=open",
        "forum": "https://www.phpmall.net/forum/",
        "wiki": "https://www.phpmall.net/wiki/",
        "source": "https://github.com/phpmall/phpmall"
    },
    "require": {
        "php": "^8.2",
        "alibabacloud/aliyun-log-php-sdk": "^0.6.3",
        "aliyuncs/oss-sdk-php": "^2.7",
        "endroid/qr-code": "^5.0",
        "elasticsearch/elasticsearch": "^8.10",
        "firebase/php-jwt": "^6.10",
        "intervention/image": "^3.4",
        "laravel/framework": "^11.0",
        "laravel/octane": "^2.3",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.9",
        "overtrue/easy-sms": "^2.6",
        "overtrue/pinyin": "^5.3",
        "overtrue/socialite": "^4.9",
        "phpoffice/phpspreadsheet": "^2.0",
        "qcloud/cos-sdk-v5": "^2.6",
        "qiniu/php-sdk": "^7.12",
        "w7corp/easywechat": "^6.15",
        "workerman/crontab": "^1.0",
        "workerman/gateway-worker": "^3.1",
        "yansongda/pay": "^3.6"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/breeze": "^2.0",
        "laravel/pint": "^1.14",
        "laravel/sail": "^1.28",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.5",
        "spatie/laravel-ignition": "^2.4",
        "zircote/swagger-php": "^4.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
