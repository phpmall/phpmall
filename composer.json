{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "phpmall/phpmall",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "phpmall"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "alibabacloud/aliyun-log-php-sdk": "^0.6.8",
        "aliyuncs/oss-sdk-php": "^2.7",
        "elasticsearch/elasticsearch": "^9.4",
        "endroid/qr-code": "^6.1",
        "filament/filament": "^5.6",
        "inertiajs/inertia-laravel": "^3.1",
        "intervention/image": "^4.0",
        "laravel/framework": "^13.8",
        "laravel/octane": "^2.17",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^3.0",
        "overtrue/laravel-easy-sms": "^4.0",
        "overtrue/laravel-pinyin": "^6.1",
        "overtrue/laravel-socialite": "^4.1",
        "overtrue/laravel-wechat": "^8.0",
        "phpkg/laravel-auth": "^1.0",
        "phpkg/laravel-captcha": "^1.0",
        "phpkg/laravel-foundation": "^1.0",
        "phpoffice/phpspreadsheet": "^5.7",
        "workerman/crontab": "^1.0",
        "workerman/gateway-worker": "^4.0",
        "yansongda/laravel-pay": "^3.7"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "kitloong/laravel-migrations-generator": "^7.3",
        "laravel-lang/lang": "^15.29",
        "laravel/boost": "^2.4",
        "laravel/breeze": "^2.4",
        "laravel/pail": "^1.2.5",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpkg/laravel-devtools": "^1.0",
        "larastan/larastan": "^3.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.5.12",
        "zircote/swagger-php": "^6.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "lint": [
            "@php vendor/bin/pint --config=pint.json"
        ],
        "lint:check": [
            "@php vendor/bin/pint --config=pint.json --test"
        ],
        "analyse": [
            "@php vendor/bin/phpstan analyse --configuration=phpstan.neon --memory-limit=1G"
        ],
        "check": [
            "@lint:check",
            "@analyse",
            "@test"
        ],
        "git-hooks": [
            "@php -r \"is_dir('.githooks') || mkdir('.githooks', 0755, true);\"",
            "git config core.hooksPath .githooks"
        ],
        "test": [
            "@php artisan config:clear --ansi @no_additional_args",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
